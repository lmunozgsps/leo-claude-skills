#%RAML 1.0 Trait
# Trait reutilizable de paginación basada en cursor. Publicable en Exchange.
queryParameters:
  cursor:
    type: string
    required: false
    description: Cursor opaco para la siguiente página. Omitir en la primera.
    maxLength: 512
  limit:
    type: integer
    required: false
    default: 20
    minimum: 1
    maximum: 100
    description: Número máximo de elementos por página.
